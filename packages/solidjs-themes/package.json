{
  "name": "solidjs-themes",
  "version": "0.1.0",
  "description": "Theme management for SolidJS and SolidStart – a port of next-themes",
  "keywords": [
    "solidjs",
    "solid",
    "solidstart",
    "theme",
    "dark-mode",
    "dark-theme",
    "color-scheme",
    "prefers-color-scheme",
    "ssr",
    "fouc"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imapotatoes11/solidjs-themes.git"
  },
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "solid": {
        "import": "./src/index.tsx",
        "require": "./src/index.tsx"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.0.0",
    "babel-preset-solid": "^1.9.3",
    "esbuild-plugin-solid": "^0.6.0",
    "jsdom": "^24.0.0",
    "solid-js": "^1.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.4.2",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^1.6.1"
  }
}
